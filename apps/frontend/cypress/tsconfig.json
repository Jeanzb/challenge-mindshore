{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["cypress", "cypress-real-events", "node"],
    "isolatedModules": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["**/*.ts"]
}
